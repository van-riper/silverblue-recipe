#!/usr/bin/env bash
#
# silverblue-recipe: capture and replay the reproducible
# OS layer of a Fedora Atomic (Silverblue) host.
#
set -euo pipefail

PROGNAME=${0##*/}
DEFAULT_SUBDIR=".local/share/silverblue-recipe"

die() {
  printf '%s: %s\n' "$PROGNAME" "$*" >&2
  exit 1
}

run_or_print() {
  local dry=$1
  shift
  if [[ $dry == 1 ]]; then
    printf '%s\n' "$*"
  else
    "$@"
  fi
}

require_root() {
  [[ $EUID -eq 0 ]] || die "must run as root (use sudo): $PROGNAME $1"
}

resolve_target_user() {
  local want=$1
  if [[ -n $want ]]; then
    printf '%s\n' "$want"
    return
  fi
  if [[ -n ${SUDO_USER:-} && $SUDO_USER != root ]]; then
    printf '%s\n' "$SUDO_USER"
    return
  fi
  die "cannot determine target user; pass --user <name>"
}

user_home() {
  local user=$1 home
  home=$(getent passwd "$user" | cut -d: -f6) || true
  [[ -n $home ]] || die "no home directory for user: $user"
  printf '%s\n' "$home"
}

recipe_dir_root() {
  local out=$1 user=$2
  if [[ -n $out ]]; then
    printf '%s\n' "$out"
    return
  fi
  printf '%s/%s\n' "$(user_home "$user")" "$DEFAULT_SUBDIR"
}

recipe_dir_user() {
  local out=$1
  if [[ -n $out ]]; then
    printf '%s\n' "$out"
    return
  fi
  printf '%s/%s\n' "$HOME" "$DEFAULT_SUBDIR"
}

as_user() {
  sudo -n -u "$TARGET_USER" "$@"
}

live_origin_paths() {
  local f
  for f in /ostree/deploy/*/deploy/*.origin; do
    [[ -e $f ]] && printf '%s\n' "$f"
  done
}

archive_origin() {
  local dir=$1 file=$2 hash a
  hash=$(sha256sum "$file" | cut -d' ' -f1)
  for a in "$dir"/origins/history/*.origin; do
    [[ -e $a ]] || continue
    if [[ $(sha256sum "$a" | cut -d' ' -f1) == "$hash" ]]; then
      as_user rm -f "$file"
      return
    fi
  done
  as_user mv "$file" "$dir/origins/history/$(basename "$file")"
}

capture_origins() {
  local dir=$1 f base existing ebase
  as_user mkdir -p "$dir/origins" "$dir/origins/history"

  local live=()
  while IFS= read -r f; do
    live+=("$(basename "$f")")
  done < <(live_origin_paths)

  for existing in "$dir"/origins/*.origin; do
    [[ -e $existing ]] || continue
    ebase=$(basename "$existing")
    if ! printf '%s\n' "${live[@]}" | grep -qxF "$ebase"; then
      archive_origin "$dir" "$existing"
    fi
  done

  while IFS= read -r f; do
    base=$(basename "$f")
    as_user tee "$dir/origins/$base" >/dev/null < "$f"
  done < <(live_origin_paths)
}

cmd_capture() {
  local want_user="" out=""
  while [[ $# -gt 0 ]]; do
    case $1 in
      --user)       want_user=${2:-}; shift 2 ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "capture: unknown option: $1" ;;
    esac
  done
  require_root capture
  TARGET_USER=$(resolve_target_user "$want_user")
  RECIPE_DIR=$(recipe_dir_root "$out" "$TARGET_USER")
  as_user mkdir -p "$RECIPE_DIR"

  rpm-ostree status | as_user tee "$RECIPE_DIR/rpm-ostree-status.txt" >/dev/null
  capture_origins "$RECIPE_DIR"
  as_user flatpak remotes --columns=name,url \
    | as_user tee "$RECIPE_DIR/flatpak-remotes.txt" >/dev/null
  as_user flatpak list --app --columns=application,origin \
    | as_user tee "$RECIPE_DIR/flatpak-apps.txt" >/dev/null
  { ostree admin config-diff || true; } | sort \
    | as_user tee "$RECIPE_DIR/etc-config-diff.txt" >/dev/null
  tar --zstd -c --ignore-failed-read \
    -C / etc var/roothome var/lib/bluetooth var/lib/fprint \
    var/lib/systemd/linger var/lib/AccountsService \
    | as_user tee "$RECIPE_DIR/system-state.tar.zst" >/dev/null

  printf 'Recipe written to %s\n' "$RECIPE_DIR"
}

cmd_restore_packages() {
  local dry=0 out=""
  while [[ $# -gt 0 ]]; do
    case $1 in
      --dry-run)    dry=1; shift ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "restore-packages: unknown option: $1" ;;
    esac
  done
  local dir origin base pkgs rems
  dir=$(recipe_dir_user "$out")
  # Origin filenames are deployment checksums, so ls is safe here.
  # shellcheck disable=SC2012
  origin=$(ls -t "$dir"/origins/*.origin 2>/dev/null | head -1) || true
  [[ -n $origin ]] || die "no origin files in $dir/origins"
  base=$(awk -F= '/^baserefspec=/{print $2}' "$origin")
  pkgs=$(awk -F= '/^requested=/{print $2}' "$origin" | tr ';' ' ')
  rems=$(awk -F= '/^remove=/{print $2}' "$origin" | tr ';' ' ')
  [[ -n $base ]] && printf '# base image: %s\n' "$base"
  # shellcheck disable=SC2086
  [[ -n ${pkgs// /} ]] && run_or_print "$dry" rpm-ostree install $pkgs
  # shellcheck disable=SC2086
  [[ -n ${rems// /} ]] && run_or_print "$dry" rpm-ostree override remove $rems
  return 0
}

cmd_restore_flatpaks() {
  local dry=0 out="" scope=--system
  while [[ $# -gt 0 ]]; do
    case $1 in
      --dry-run)    dry=1; shift ;;
      --user)       scope=--user; shift ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "restore-flatpaks: unknown option: $1" ;;
    esac
  done
  local dir app origin
  dir=$(recipe_dir_user "$out")
  [[ -f "$dir/flatpak-apps.txt" ]] || die "missing $dir/flatpak-apps.txt"
  while read -r app origin; do
    [[ -n $app ]] || continue
    run_or_print "$dry" flatpak install -y "$scope" "${origin:-flathub}" "$app"
  done < "$dir/flatpak-apps.txt"
}

usage() {
  cat <<'EOF'
Usage: silverblue-recipe <command> [options]

Commands:
  capture            Regenerate the recipe (root)
  restore-packages   Re-layer rpm-ostree packages from the recipe
  restore-flatpaks   Reinstall flatpaks from the recipe
  restore-config     Untar captured /etc + /var state over / (root)

Options:
  --user <name>      (capture) target user; defaults to $SUDO_USER under sudo
  --user             (restore-flatpaks) install per-user, not system-wide
  --output-dir <dir> Override the recipe directory
  --dry-run          (restore-*) print commands without running them
  -h, --help         Show this help
EOF
}

main() {
  local cmd=${1:-}
  [[ -n $cmd ]] || { usage; exit 1; }
  shift
  case $cmd in
    -h|--help|help) usage ;;
    capture) cmd_capture "$@" ;;
    restore-packages) cmd_restore_packages "$@" ;;
    restore-flatpaks) cmd_restore_flatpaks "$@" ;;
    restore-config)   die "restore-config not implemented yet" ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

if [[ ${BASH_SOURCE[0]:-} == "${0}" ]]; then
  main "$@"
fi
