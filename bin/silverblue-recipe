#!/usr/bin/env bash
#
# silverblue-recipe: capture and replay the reproducible
# OS layer of a Fedora Atomic (Silverblue) host.
#
set -euo pipefail

PROGNAME=${0##*/}
DEFAULT_SUBDIR=".local/share/silverblue-recipe"

die() {
  printf '%s: %s\n' "$PROGNAME" "$*" >&2
  exit 1
}

require_root() {
  [[ $EUID -eq 0 ]] || die "must run as root (use sudo): $PROGNAME $1"
}

resolve_target_user() {
  local want=$1
  if [[ -n $want ]]; then
    printf '%s\n' "$want"
    return
  fi
  if [[ -n ${SUDO_USER:-} && $SUDO_USER != root ]]; then
    printf '%s\n' "$SUDO_USER"
    return
  fi
  die "cannot determine target user; pass --user <name>"
}

user_home() {
  local user=$1 home
  home=$(getent passwd "$user" | cut -d: -f6) || true
  [[ -n $home ]] || die "no home directory for user: $user"
  printf '%s\n' "$home"
}

recipe_dir_root() {
  local out=$1 user=$2
  if [[ -n $out ]]; then
    printf '%s\n' "$out"
    return
  fi
  printf '%s/%s\n' "$(user_home "$user")" "$DEFAULT_SUBDIR"
}

recipe_dir_user() {
  local out=$1
  if [[ -n $out ]]; then
    printf '%s\n' "$out"
    return
  fi
  printf '%s/%s\n' "$HOME" "$DEFAULT_SUBDIR"
}

as_user() {
  sudo -n -u "$TARGET_USER" "$@"
}

cmd_capture() {
  local want_user="" out=""
  while [[ $# -gt 0 ]]; do
    case $1 in
      --user)       want_user=${2:-}; shift 2 ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "capture: unknown option: $1" ;;
    esac
  done
  require_root capture
  TARGET_USER=$(resolve_target_user "$want_user")
  RECIPE_DIR=$(recipe_dir_root "$out" "$TARGET_USER")
  as_user mkdir -p "$RECIPE_DIR"

  rpm-ostree status | as_user tee "$RECIPE_DIR/rpm-ostree-status.txt" >/dev/null
  capture_origins "$RECIPE_DIR"
  as_user flatpak remotes --columns=name,url \
    | as_user tee "$RECIPE_DIR/flatpak-remotes.txt" >/dev/null
  as_user flatpak list --app --columns=application,origin \
    | as_user tee "$RECIPE_DIR/flatpak-apps.txt" >/dev/null
  { ostree admin config-diff || true; } | sort \
    | as_user tee "$RECIPE_DIR/etc-config-diff.txt" >/dev/null
  tar --zstd -c --ignore-failed-read \
    -C / etc var/roothome var/lib/bluetooth var/lib/fprint \
    var/lib/systemd/linger var/lib/AccountsService \
    | as_user tee "$RECIPE_DIR/system-state.tar.zst" >/dev/null

  printf 'Recipe written to %s\n' "$RECIPE_DIR"
}

usage() {
  cat <<'EOF'
Usage: silverblue-recipe <command> [options]

Commands:
  capture            Regenerate the recipe (root)
  restore-packages   Re-layer rpm-ostree packages from the recipe
  restore-flatpaks   Reinstall flatpaks from the recipe
  restore-config     Untar captured /etc + /var state over / (root)

Options:
  --user <name>      (capture) target user; defaults to $SUDO_USER under sudo
  --user             (restore-flatpaks) install per-user, not system-wide
  --output-dir <dir> Override the recipe directory
  --dry-run          (restore-*) print commands without running them
  -h, --help         Show this help
EOF
}

main() {
  local cmd=${1:-}
  [[ -n $cmd ]] || { usage; exit 1; }
  shift
  case $cmd in
    -h|--help|help) usage ;;
    capture) cmd_capture "$@" ;;
    restore-packages) die "restore-packages not implemented yet" ;;
    restore-flatpaks) die "restore-flatpaks not implemented yet" ;;
    restore-config)   die "restore-config not implemented yet" ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

if [[ ${BASH_SOURCE[0]:-} == "${0}" ]]; then
  main "$@"
fi
