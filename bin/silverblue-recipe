#!/usr/bin/env bash
#
# silverblue-recipe: capture and restore the reproducible
# ostree layer of a Fedora Silverblue installation.
#
set -euo pipefail

PROGNAME=${0##*/}
VERSION='0.1.0'
DEFAULT_SUBDIR='.local/share/silverblue-recipe'

# /etc files carrying machine identity, accounts, or storage UUIDs.
# Running 'sudo silverblue-recipe restore-config --apply' never
# writes these to a live system; restore them by hand if you must.
RESTORE_EXCLUDES=(
  etc/.pwd.lock                  # passwd/shadow edit lock
  etc/.rpm-ostree-shadow-mode-fixed2.stamp # rpm-ostree migration stamp
  etc/.updated                   # first-boot timestamp marker
  etc/crypttab                   # LUKS device UUIDs
  etc/fstab                      # filesystem mount UUIDs
  etc/group etc/group-           # local groups
  etc/gshadow etc/gshadow-       # group password hashes
  etc/iscsi/initiatorname.iscsi  # iSCSI host identity
  etc/krb5.keytab                # Kerberos host keys
  etc/machine-id                 # unique machine identifier
  etc/machine-info               # chassis/hardware metadata
  etc/mdadm.conf                 # RAID array UUIDs
  etc/mdadm/mdadm.conf           # RAID array UUIDs (alt path)
  etc/nvme/hostid                # NVMe host id
  etc/nvme/hostnqn               # NVMe host NQN
  etc/passwd etc/passwd-         # local user accounts
  'etc/pki/tls/private/*'        # host TLS private keys
  etc/salt/minion_id             # Salt minion identity
  'etc/selinux/targeted/*.LOCK'  # SELinux policy DB locks
  etc/selinux/targeted/active    # SELinux module store
  etc/shadow etc/shadow-         # user password hashes
  'etc/ssh/ssh_host_*'           # SSH host keys
  etc/subgid etc/subgid-         # subordinate GID ranges
  etc/subuid etc/subuid-         # subordinate UID ranges
  etc/sudoers                    # sudo policy
  'etc/wireguard/*'              # WireGuard private keys
)

die() {
  printf '%s: %s\n' "$PROGNAME" "$*" >&2
  exit 1
}

run_or_print() {
  local dry=$1
  shift

  if [[ $dry == 1 ]]; then
    printf '%s\n' "$*"
  else
    "$@"
  fi
}

require_root() {
  [[ $EUID -eq 0 ]] || die "must run as root (use sudo): $PROGNAME $1"
}

resolve_target_user() {
  local want=$1

  if [[ -n $want ]]; then
    printf '%s\n' "$want"
    return
  fi
  if [[ -n ${SUDO_USER:-} && $SUDO_USER != root ]]; then
    printf '%s\n' "$SUDO_USER"
    return
  fi

  die 'cannot determine target user, try passing --user <username>'
}

user_home() {
  local user=$1 home

  home=$(getent passwd "$user" | cut -d: -f6) || true
  [[ -n $home ]] || die "no home directory for user: $user"

  printf '%s\n' "$home"
}

recipe_dir_root() {
  local out=$1 user=$2

  if [[ -n $out ]]; then
    printf '%s\n' "$out"
    return
  fi

  printf '%s/%s\n' "$(user_home "$user")" "$DEFAULT_SUBDIR"
}

recipe_dir_user() {
  local out=$1

  if [[ -n $out ]]; then
    printf '%s\n' "$out"
    return
  fi

  printf '%s/%s\n' "$HOME" "$DEFAULT_SUBDIR"
}

as_user() {
  sudo -n -u "$TARGET_USER" "$@"
}

live_origin_paths() {
  local f

  for f in /ostree/deploy/*/deploy/*.origin; do
    [[ -e $f ]] && printf '%s\n' "$f"
  done
}

archive_origin() {
  local dir=$1 file=$2 hash a
  hash=$(sha256sum "$file" | cut -d' ' -f1)

  for a in "$dir"/origins/history/*.origin; do
    [[ -e $a ]] || continue
    if [[ $(sha256sum "$a" | cut -d' ' -f1) == "$hash" ]]; then
      as_user rm -f "$file"
      return
    fi
  done

  as_user mv "$file" "$dir/origins/history/$(basename "$file")"
}

capture_origins() {
  local dir=$1 f base existing ebase
  as_user mkdir -p "$dir/origins" "$dir/origins/history"

  local live=()
  while IFS= read -r f; do
    live+=("$(basename "$f")")
  done < <(live_origin_paths)

  for existing in "$dir"/origins/*.origin; do
    [[ -e $existing ]] || continue
    ebase=$(basename "$existing")
    if ! printf '%s\n' "${live[@]}" | grep -qxF "$ebase"; then
      archive_origin "$dir" "$existing"
    fi
  done

  while IFS= read -r f; do
    base=$(basename "$f")
    as_user tee "$dir/origins/$base" >/dev/null < "$f"
  done < <(live_origin_paths)
}

cmd_capture() {
  local want_user='' out='' recipe_dir

  while [[ $# -gt 0 ]]; do
    case $1 in
      --user)       want_user=${2:-}; shift 2 ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "capture: unknown option: $1" ;;
    esac
  done

  require_root capture

  # TARGET_USER is global on purpose: as_user and capture_origins read it.
  TARGET_USER=$(resolve_target_user "$want_user")
  recipe_dir=$(recipe_dir_root "$out" "$TARGET_USER")
  as_user mkdir -p "$recipe_dir"

  rpm-ostree status | as_user tee "$recipe_dir/rpm-ostree-status.txt" >/dev/null
  capture_origins "$recipe_dir"
  as_user flatpak remotes --columns=name,url \
    | as_user tee "$recipe_dir/flatpak-remotes.txt" >/dev/null
  as_user flatpak list --app --columns=application,origin \
    | as_user tee "$recipe_dir/flatpak-apps.txt" >/dev/null
  { ostree admin config-diff || true; } | sort \
    | as_user tee "$recipe_dir/etc-config-diff.txt" >/dev/null
  tar --zstd -c --ignore-failed-read --acls --xattrs --selinux \
    -C / etc var/roothome var/lib/bluetooth var/lib/fprint \
    var/lib/systemd/linger var/lib/AccountsService \
    | as_user tee "$recipe_dir/system-state.tar.zst" >/dev/null

  printf 'Recipe written to %s\n' "$recipe_dir"
}

cmd_restore_packages() {
  local dry=0 out=''

  while [[ $# -gt 0 ]]; do
    case $1 in
      --dry-run)    dry=1; shift ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "restore-packages: unknown option: $1" ;;
    esac
  done

  local dir origin base pkgs rems
  dir=$(recipe_dir_user "$out")

  # Origin filenames are deployment checksums, so ls is safe here.
  # shellcheck disable=SC2012
  origin=$(ls -t "$dir"/origins/*.origin 2>/dev/null | head -1) || true
  [[ -n $origin ]] || die "no origin files in $dir/origins"

  base=$(awk -F= '/^baserefspec=/{print $2}' "$origin")
  pkgs=$(awk -F= '/^requested=/{print $2}' "$origin" | tr ';' ' ')
  rems=$(awk -F= '/^remove=/{print $2}' "$origin" | tr ';' ' ')

  [[ -n $base ]] && printf '# base image: %s\n' "$base"
  # shellcheck disable=SC2086
  [[ -n ${pkgs// /} ]] && run_or_print "$dry" rpm-ostree install $pkgs
  # shellcheck disable=SC2086
  [[ -n ${rems// /} ]] && run_or_print "$dry" rpm-ostree override remove $rems
  return 0
}

cmd_restore_flatpaks() {
  local dry=0 out='' scope=--system

  while [[ $# -gt 0 ]]; do
    case $1 in
      --dry-run)    dry=1; shift ;;
      --user)       scope=--user; shift ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "restore-flatpaks: unknown option: $1" ;;
    esac
  done

  local dir app origin
  dir=$(recipe_dir_user "$out")
  [[ -f $dir/flatpak-apps.txt ]] || die "missing $dir/flatpak-apps.txt"

  while read -r app origin; do
    [[ -n $app ]] || continue
    run_or_print "$dry" flatpak install -y "$scope" "${origin:-flathub}" "$app"
  done < "$dir/flatpak-apps.txt"
}

confirm_restore_config() {
  cat >&2 <<'EOF'
WARNING: restore-config will overwrite /etc and parts of /var on this system.
You WILL lose data, so DO NOT run it unless you're on a fresh install.
EOF
  printf 'Proceed? [y/N] ' >&2

  local answer=''
  read -r answer || true
  [[ $answer == [yY] ]] || die 'restore-config aborted'
}

cmd_restore_config() {
  local dry=0 apply=0 out='' want_user=''

  while [[ $# -gt 0 ]]; do
    case $1 in
      --dry-run)    dry=1; shift ;;
      --apply)      apply=1; shift ;;
      --user)       want_user=${2:-}; shift 2 ;;
      --output-dir) out=${2:-}; shift 2 ;;
      *) die "restore-config: unknown option: $1" ;;
    esac
  done

  require_root restore-config

  local user dir tarball
  user=$(resolve_target_user "$want_user")
  dir=$(recipe_dir_root "$out" "$user")
  tarball="$dir/system-state.tar.zst"
  [[ -f $tarball ]] || die "missing $tarball"

  local excludes=() pat
  for pat in "${RESTORE_EXCLUDES[@]}"; do
    excludes+=("--exclude=$pat")
  done
  local apply_cmd=(
    tar -C / --zstd --acls --xattrs --selinux
    "${excludes[@]}" -xf "$tarball"
  )

  if [[ $dry -eq 1 ]]; then
    printf '%s\n' "${apply_cmd[*]}"
    return 0
  fi

  if [[ $apply -eq 1 ]]; then
    confirm_restore_config
    "${apply_cmd[@]}"
    restorecon -R /etc /var/roothome /var/lib/bluetooth /var/lib/fprint \
      /var/lib/systemd/linger /var/lib/AccountsService 2>/dev/null || true
    return 0
  fi

  local review
  review=$(mktemp -d /var/tmp/silverblue-recipe-etc.XXXXXX)
  tar -C "$review" --zstd -xf "$tarball"

  printf 'Extracted config to %s for review.\n' "$review"
  printf 'Copy what you want by hand, or rerun with --apply to overlay onto /\n'
  printf '(identity files like machine-id, fstab, and ssh keys are skipped).\n'
}

usage() {
  cat <<'EOF'
Usage: silverblue-recipe <command> [options]

Commands:
  capture             Regenerate the recipe (root)
  restore-packages    Re-layer rpm-ostree packages from the recipe
  restore-flatpaks    Reinstall flatpaks from the recipe
  restore-config      Stage captured /etc + /var for review (root)

Options:
  --user <name>       (capture) target user; defaults to $SUDO_USER under sudo
  --user              (restore-flatpaks) install per-user, not system-wide
  --apply             (restore-config) overlay reviewed config onto / (root)
  --output-dir <path> Override the recipe directory
  --dry-run           (restore-*) print commands without running them
  -h, --help          Show this help message
  -v, --version       Show version information
EOF
}

main() {
  local cmd=${1:-}
  [[ -n $cmd ]] || { usage; exit 1; }
  shift

  case $cmd in
    -h|--help|help) usage ;;
    -v|--version|version) printf '%s %s\n' "$PROGNAME" "$VERSION" ;;
    capture) cmd_capture "$@" ;;
    restore-packages) cmd_restore_packages "$@" ;;
    restore-flatpaks) cmd_restore_flatpaks "$@" ;;
    restore-config) cmd_restore_config "$@" ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

if [[ ${BASH_SOURCE[0]:-} == "${0}" ]]; then
  main "$@"
fi
